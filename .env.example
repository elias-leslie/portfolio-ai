# Portfolio AI Environment Variables
# Copy to .env.local for native installs or .env for Docker compose.
# Repo-local env files are preferred. ~/.env.local is only a fallback for the
# existing internal SummitFlow runtime.

# ---------------------------------------------------------------------------
# Native standalone baseline
# ---------------------------------------------------------------------------

# Leave these blank for the bundled Docker quickstart so docker-compose can
# inject the container-internal service URLs automatically.
PORTFOLIO_DB_URL=
REDIS_URL=
HATCHET_CLIENT_TOKEN=replace-with-generated-token
HATCHET_CLIENT_HOST_PORT=127.0.0.1:7070
HATCHET_CLIENT_TLS_STRATEGY=none

# Native example values:
# PORTFOLIO_DB_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio_ai
# REDIS_URL=redis://localhost:6379/0

# Self-referencing URLs used by the backend for generated links and callbacks.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Additional frontend origins when you expose the UI on a custom host/port.
# FRONTEND_HOST=192.168.1.100
# FRONTEND_EXTRA_ORIGINS=http://custom-host:3000,https://custom-host:3000

# Optional storage/cache settings.
# ARTIFACTS_DIR=/path/to/artifacts
# CACHE_ENABLED=true
# CACHE_MAX_SIZE=1000
# CACHE_DEFAULT_TTL=300

# ---------------------------------------------------------------------------
# Docker compose
# ---------------------------------------------------------------------------

# Docker defaults to the same local ports as the native runtime.
# Override these if your machine already uses the defaults.
# PORTFOLIO_FRONTEND_HOST_PORT=3000
# PORTFOLIO_BACKEND_HOST_PORT=8000
# PORTFOLIO_DB_HOST_PORT=5432
# PORTFOLIO_REDIS_HOST_PORT=6379
# HATCHET_GRPC_HOST_PORT=7070
# HATCHET_HEALTH_HOST_PORT=8888

# Postgres password for the bundled Docker stack.
# POSTGRES_PASSWORD=portfolio

# Hatchet quickstart configuration.
# generate-hatchet-dev-token.sh writes both HATCHET_TENANT_ID and
# HATCHET_CLIENT_TOKEN for the tenant created by quickstart. Override
# HATCHET_TENANT_ID only if you created a different tenant yourself.
# HATCHET_TAG=latest
# HATCHET_TENANT_ID=707d0855-80ab-4e1f-a156-f1c4546cbf52

# ---------------------------------------------------------------------------
# Agent Hub companion mode
# ---------------------------------------------------------------------------

# Companion mode is optional. Set these only when Agent Hub is running
# separately and you want Jenny/chat/thesis/document-review features enabled.
# AGENT_HUB_URL=http://localhost:8003
# PORTFOLIO_CLIENT_ID=your-client-id
# PORTFOLIO_REQUEST_SOURCE=portfolio-ai

# ---------------------------------------------------------------------------
# Optional market-data API keys
# ---------------------------------------------------------------------------

# POLYGON_API_KEY=your_key_here
# TWELVEDATA_API_KEY=your_key_here
# FMP_API_KEY=your_key_here
# FINNHUB_API_KEY=your_key_here
# ALPHAVANTAGE_API_KEY=your_key_here
