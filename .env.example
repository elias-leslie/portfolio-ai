# Portfolio AI Environment Variables
# Copy to ~/.env.local and fill in values

# === Required ===

# PostgreSQL connection URL
PORTFOLIO_DB_URL=postgresql://user:YOUR_DB_PASSWORD@localhost:5432/portfolio_ai

# === Optional ===

# Redis connection URL (default: redis://localhost:6379)
# REDIS_URL=redis://localhost:6379

# Directory for artifact storage (default: <project-root>/data/artifacts)
# ARTIFACTS_DIR=/path/to/artifacts

# Agent Hub integration (auto-enabled when both are set)
# PORTFOLIO_CLIENT_ID=your-client-id
# PORTFOLIO_CLIENT_SECRET=your-client-secret
