# Portfolio AI Environment Variables
# Copy to .env for Docker Compose or .env.local for native installs.
# Keep real credentials in local env files only; never commit them.

# ---------------------------------------------------------------------------
# Core runtime
# ---------------------------------------------------------------------------

# Leave these blank for the bundled Docker quickstart so Docker Compose can
# inject container-internal service URLs automatically.
PORTFOLIO_DB_URL=
REDIS_URL=

# Native examples:
# PORTFOLIO_DB_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio_ai
# REDIS_URL=redis://localhost:6379/0

HATCHET_CLIENT_TOKEN=replace-with-generated-token
HATCHET_CLIENT_HOST_PORT=127.0.0.1:7070
HATCHET_CLIENT_TLS_STRATEGY=none

# Self-referencing URLs used for generated links, callbacks, and CORS.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Additional frontend origins when you expose the UI on a custom local host.
# FRONTEND_HOST=localhost
# FRONTEND_EXTRA_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional storage/cache settings.
# ARTIFACTS_DIR=/path/to/artifacts
# CACHE_ENABLED=true
# CACHE_MAX_SIZE=1000
# CACHE_DEFAULT_TTL=300

# Optional secret used only when encrypted provider credentials are stored.
# Generate a local value with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PORTFOLIO_SECRET_KEY=replace-with-local-random-secret

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------

# Docker defaults to common local ports. Override if your machine already uses them.
# PORTFOLIO_FRONTEND_HOST_PORT=3000
# PORTFOLIO_BACKEND_HOST_PORT=8000
# PORTFOLIO_DB_HOST_PORT=5432
# PORTFOLIO_REDIS_HOST_PORT=6379
# HATCHET_GRPC_HOST_PORT=7070
# HATCHET_HEALTH_HOST_PORT=8888

# Local password for the bundled Docker database. Change for shared machines.
# POSTGRES_PASSWORD=portfolio

# scripts/generate-hatchet-dev-token.sh writes both HATCHET_TENANT_ID and
# HATCHET_CLIENT_TOKEN for the tenant created by Hatchet quickstart.
# HATCHET_TAG=latest
# HATCHET_TENANT_ID=707d0855-80ab-4e1f-a156-f1c4546cbf52

# ---------------------------------------------------------------------------
# Optional Agent Hub companion mode
# ---------------------------------------------------------------------------

# Set these only when Agent Hub is running separately and you want companion
# AI/chat/thesis/document-review features enabled.
# AGENT_HUB_URL=http://localhost:8003
# PORTFOLIO_CLIENT_ID=your-client-id
# PORTFOLIO_REQUEST_SOURCE=portfolio-ai

# ---------------------------------------------------------------------------
# Optional market-data API keys
# ---------------------------------------------------------------------------

# POLYGON_API_KEY=your_key_here
# TWELVEDATA_API_KEY=your_key_here
# FMP_API_KEY=your_key_here
# FINNHUB_API_KEY=your_key_here
# ALPHAVANTAGE_API_KEY=your_key_here
# FRED_API_KEY=your_key_here
# SERPAPI_API_KEY=your_key_here
