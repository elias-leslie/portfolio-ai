# Portfolio AI Environment Variables
# Copy to ~/.env.local and fill in values

# === Required ===

# PostgreSQL connection URL
PORTFOLIO_DB_URL=postgresql://user:YOUR_DB_PASSWORD@localhost:5432/portfolio_ai

# === Optional ===

# Redis connection URL (default: redis://localhost:6379)
# REDIS_URL=redis://localhost:6379

# Directory for artifact storage (default: <project-root>/data/artifacts)
# ARTIFACTS_DIR=/path/to/artifacts

# Response caching
# CACHE_ENABLED=true
# CACHE_MAX_SIZE=1000
# CACHE_DEFAULT_TTL=300

# CORS — additional frontend origins (comma-separated)
# FRONTEND_HOST=192.168.1.100
# FRONTEND_EXTRA_ORIGINS=http://custom-host:3000

# Self-referencing URLs for internal service calls
# BACKEND_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000

# Agent Hub integration (auto-enabled when both are set)
# AGENT_HUB_URL=http://localhost:8003
# PORTFOLIO_CLIENT_ID=your-client-id
# PORTFOLIO_CLIENT_SECRET=your-client-secret
# PORTFOLIO_REQUEST_SOURCE=portfolio-ai

# Data source API keys
# POLYGON_API_KEY=your_key_here
# TWELVEDATA_API_KEY=your_key_here
# FMP_API_KEY=your_key_here
# FINNHUB_API_KEY=your_key_here
# ALPHAVANTAGE_API_KEY=your_key_here
