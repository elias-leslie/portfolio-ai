# Portfolio AI Environment Variables
# Copy to ~/.env.local and fill in values

# === Required ===

# PostgreSQL connection URL
PORTFOLIO_DB_URL=postgresql://user:password@localhost:5432/portfolio_ai

# === Optional ===

# Redis connection URL (default: redis://localhost:6379)
# REDIS_URL=redis://localhost:6379

# Directory for artifact storage (default: <project-root>/data/artifacts)
# ARTIFACTS_DIR=/path/to/artifacts

# Path to Claude CLI binary (default: auto-detected via PATH)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Agent Hub integration
# AGENT_HUB_ENABLED=false
# PORTFOLIO_CLIENT_ID=
# PORTFOLIO_CLIENT_SECRET=
