{
  "_comment": "Template MCP server config for the portfolio-ai signal stack. Copy to .mcp.json in the consuming project. Update 'cwd' to this repository's backend/ directory so 'uv run' resolves the project environment.",
  "mcpServers": {
    "portfolio-ai": {
      "command": "uv",
      "args": ["run", "portfolio-ai-mcp"],
      "cwd": "/absolute/path/to/portfolio-ai/backend"
    }
  }
}
